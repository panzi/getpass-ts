{
  "name": "@panzi/getpass",
  "version": "1.1.0",
  "description": "Simple password prompt for the command line.",
  "keywords": [
    "password",
    "cli"
  ],
  "license": "MIT",
  "author": "Mathias Panzenböck",
  "homepage": "https://github.com/panzi/getpass-ts#readme",
  "bugs": {
    "url": "https://github.com/panzi/getpass-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panzi/getpass-ts.git"
  },
  "main": "./build/cjs/index.js",
  "types": "./build/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/types/index.d.ts",
      "require": "./build/cjs/index.js",
      "import": "./build/esm/index.mjs",
      "default": "./build/esm/index.mjs"
    }
  },
  "scripts": {
    "test": "jest",
    "clean": "rm -rf build",
    "build": "npm run build:types && npm run build:cjs && npm run build:esm",
    "build:clean": "npm run clean && npm run build",
    "build:types": "npx tsc --outDir build/types --declaration --emitDeclarationOnly",
    "build:cjs": "npx tsc --module commonjs --outDir build/cjs --declaration",
    "build:esm": "npx tsc --module es2022 --outDir build/esm && node ./fix-esm.mjs",
    "build:doc": "typedoc src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "node-pty": "^1.1.0",
    "ts-jest": "^29.4.6",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3"
  }
}
